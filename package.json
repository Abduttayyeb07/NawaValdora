{
  "name": "zigchain-wallet-monitor-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade Telegram bot for ZigChain wallet monitoring.",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --packages=external --outfile=dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "dev:watch": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@cosmjs/encoding": "^0.38.1",
    "cosmjs-types": "^0.11.0",
    "dotenv": "^17.4.2",
    "googleapis": "^171.4.0",
    "pino": "^10.3.1",
    "telegraf": "^4.16.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
